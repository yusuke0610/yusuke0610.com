---

<header class="border-b border-gray-200 bg-white">
  <div
    class="mx-auto flex flex-col items-center gap-4 px-4 py-4 sm:max-w-3xl sm:flex-row sm:justify-between sm:gap-0"
  >
    <a
      href={`${base}/`}
      class="text-lg font-bold text-gray-900 hover:text-gray-600"
    >
      fudge.com
    </a>
    <nav class="flex items-center gap-4 sm:gap-6">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            class="text-sm font-medium text-gray-700 hover:text-gray-900"
          >
            {link.label}
          </a>
        ))
      }
      <div class="flex items-center gap-2 sm:ml-2 sm:gap-3">
        {
          iconLinks.map((link) => (
            <a
              href={link.href}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={link.label}
              class="text-gray-500 hover:text-gray-900"
            >
              <Fragment set:html={link.svg} />
            </a>
          ))
        }
      </div>
    </nav>
  </div>
</header>
