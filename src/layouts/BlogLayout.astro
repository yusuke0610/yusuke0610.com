---
import BaseLayout from "./BaseLayout.astro";

type Props = {
  title: string;
  description: string;
  publishedAt: Date;
  tags: string[];
};

const { title, description, publishedAt, tags } = Astro.props;

const formattedDate = new Intl.DateTimeFormat("ja-JP", {
  year: "numeric",
  month: "2-digit",
  day: "2-digit",
}).format(publishedAt);
---

<BaseLayout title={`${title} | fudge.com`} description={description}>
  <article>
    <header class="mb-8">
      <time class="text-sm text-gray-500">{formattedDate}</time>
      <h1 class="mt-2 text-2xl font-bold text-gray-900">{title}</h1>
      <p class="mt-2 text-gray-600">{description}</p>
      {
        tags.length > 0 && (
          <div class="mt-3 flex flex-wrap gap-1">
            {tags.map((tag) => (
              <span class="rounded bg-gray-100 px-2 py-0.5 text-xs text-gray-600">
                {tag}
              </span>
            ))}
          </div>
        )
      }
    </header>
    <div class="prose prose-gray max-w-none">
      <slot />
    </div>
  </article>
</BaseLayout>
