---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import BlogCard from "../components/BlogCard";

const posts = (await getCollection("blog", ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime())
  .slice(0, 3);
---

<BaseLayout title="yusuke0610.com">
  <section class="flex flex-col items-center sm:items-start">
    <h1 class="text-3xl font-bold text-gray-900 sm:text-4xl">yusuke0610</h1>
    <div class="mt-6 w-full sm:max-w-none max-w-md overflow-hidden rounded-2xl shadow-sm">
      <img
        src={`${import.meta.env.BASE_URL.replace(/\/$/, "")}/image0.png`}
        alt="yusuke0610"
        class="h-auto w-full object-cover"
      />
    </div>
  </section>
</BaseLayout>
