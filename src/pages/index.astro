---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import BlogCard from '../components/BlogCard';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime())
  .slice(0, 3);
---

<BaseLayout title="yusuke0610.com">
  <section>
    <h1 class="text-2xl font-bold text-gray-900">yusuke0610</h1>
    <p class="mt-2 text-gray-600">ソフトウェアエンジニア。日々の開発メモや個人プロジェクトを記録しています。</p>
  </section>

  <section class="mt-12">
    <div class="mb-4 flex items-center justify-between">
      <h2 class="text-lg font-semibold text-gray-900">最近の記事</h2>
      <a href="/blog" class="text-sm text-blue-600 hover:underline">すべて見る →</a>
    </div>
    <div class="flex flex-col gap-4">
      {posts.map((post) => (
        <BlogCard
          title={post.data.title}
          description={post.data.description}
          publishedAt={post.data.publishedAt}
          slug={post.id}
          tags={post.data.tags}
        />
      ))}
    </div>
  </section>
</BaseLayout>
